            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"employeeId\": \"EMP2045\",\n  \"email\": \"jane@company.com\",\n  \"password\": \"password123\",\n  \"department\": \"Engineering\",\n  \"location\": \"Mumbai\",\n  \"lob\": \"Technology\",\n  \"manager\": \"Priya Nair\",\n  \"designation\": \"Senior Analyst\"\n}",
