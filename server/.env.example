# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/learning_week

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS / client origin
CLIENT_URL=http://localhost:5173

# Social engagement scheduled sync (ms). Set to 0 to disable.
SOCIAL_SYNC_INTERVAL_MS=0
